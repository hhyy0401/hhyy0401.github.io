{% comment %}
  Unified work/experience entry renderer
  Style 1: Bold title (position or company name)
  Style 2: Normal text (company/description + highlights)
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row align-items-start">
        <div class="col-auto text-left date-column">
          {% capture start_date %}
            {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
          {% endcapture %}
          {% capture end_date %}
            {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
          {% endcapture %}

          {% if start_date != '' %}
            {% assign startDate = start_date | split: '-' | first | strip %}
            {% assign endDate = end_date | split: '-' | first | default: 'Present' | strip %}
            {% if startDate == endDate %}
              {% assign date = startDate %}
            {% else %}
              {% assign date = startDate | append: ' - ' | append: endDate %}
            {% endif %}
          {% else %}
            {% assign date = '' %}
          {% endif %}

          <table class="table-cv">
            <tbody>
              <tr>
                <td>
                  <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">{{ date }}</span>
                </td>
              </tr>
              {% capture location %}
                {% if entry.location %}{{ entry.location }}{% endif %}
              {% endcapture %}
              {% if location != '' %}
                <tr>
                  <td>
                    <p class="location" style="text-align: left;">
                      <i class="fa-solid fa-location-dot iconlocation"></i>{{ location | strip | newline_to_br }}
                    </p>
                  </td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        <div class="col mt-0">
          {% capture position_title %}
            {% if entry.position %}{{ entry.position }}{% endif %}
          {% endcapture %}
          {% assign position_title = position_title | strip %}

          {% capture company_name %}
            {% if entry.name %}{{ entry.name }}{% elsif entry.company %}{{ entry.company }}{% elsif entry.organization %}{{ entry.organization }}{% endif %}
          {% endcapture %}
          {% assign company_name = company_name | strip %}

          {% if position_title != '' and company_name != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">{{ position_title }}</h6>
            <div class="ml-1 ml-md-4" style="font-size: 0.9rem;">{{ company_name }}</div>
          {% elsif position_title != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">{{ position_title }}</h6>
          {% elsif company_name != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">{{ company_name }}</h6>
          {% endif %}

          {% if entry.summary %}
            <div class="ml-1 ml-md-4" style="font-size: 0.9rem;">
              {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
            </div>
          {% endif %}

          {% if entry.highlights %}
            <ul class="items" style="margin-top: 0.1rem;">
              {% for item in entry.highlights %}
                <li>
                  <span class="item" style="font-size: 0.9rem;">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
