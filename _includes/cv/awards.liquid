{% comment %}
  Unified awards entry renderer
  Style 1: Bold title
  Style 2: Normal text (summary)
  Location dot icon for location tag
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row align-items-start">
        {% capture start_date %}
          {% if entry.date %}{{ entry.date }}{% endif %}
        {% endcapture %}

        {% if start_date != '' %}
          <div class="col-xs-2 col-sm-2 col-md-2 text-left date-column">
            <table class="table-cv">
              <tbody>
                <tr>
                  <td>
                    <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">
                      {{- start_date | strip -}}
                    </span>
                  </td>
                </tr>
                {% capture location %}
                  {% if entry.location %}{{ entry.location }}{% endif %}
                {% endcapture %}
                {% if location != '' %}
                  <tr>
                    <td>
                      <p class="location" style="text-align: left;">
                        <i class="fa-solid fa-location-dot iconlocation" style="margin-right: 0.2rem;"></i>{{ location | strip | newline_to_br }}
                      </p>
                    </td>
                  </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
          <div class="col-xs-10 col-sm-10 col-md-10 mt-0">
            {% if entry.url %}
              <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">
                <a href="{{ entry.url }}">{{ entry.title }}</a>
              </h6>
            {% elsif entry.title %}
              <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">{{ entry.title }}</h6>
            {% endif %}

            {% if entry.summary %}
              <div class="ml-1 ml-md-4" style="font-size: 0.9rem; margin-bottom: 0;">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</div>
            {% endif %}
          </div>
        {% else %}
          <div class="col-xs-12 col-sm-12 col-md-12">
            {% if entry.url %}
              <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">
                <a href="{{ entry.url }}">{{ entry.title }}</a>
              </h6>
            {% elsif entry.title %}
              <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">{{ entry.title }}</h6>
            {% endif %}

            {% if entry.summary %}
              <div class="ml-1 ml-md-4" style="font-size: 0.9rem;">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </li>
  {% endfor %}
</ul>
