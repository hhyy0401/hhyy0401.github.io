{% comment %}
  Unified education entry renderer
  Style 1: Bold title (studyType)
  Style 2: Normal text (institution, area+highlights combined)
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row align-items-start">
        <div class="col-auto text-left date-column">
          {% capture start_date %}
            {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
          {% endcapture %}
          {% capture end_date %}
            {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
          {% endcapture %}

          {% if start_date != '' %}
            {% assign startDate = start_date | split: '-' | first %}
            {% assign endDate = end_date | split: '-' | first | default: 'Present' %}
            {% assign date = startDate | append: ' - ' | append: endDate %}
          {% else %}
            {% assign date = null %}
          {% endif %}

          <table class="table-cv">
            <tbody>
              <tr>
                <td>
                  {% if date %}
                    <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">{{ date }}</span>
                  {% endif %}
                </td>
              </tr>
              {% capture location %}
                {% if entry.location %}{{ entry.location }}{% endif %}
              {% endcapture %}
              {% if location != '' %}
                <tr>
                  <td>
                    <p class="location" style="text-align: left;">
                      <i class="fa-solid fa-location-dot iconlocation"></i>{{ location | strip | newline_to_br }}
                    </p>
                  </td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        <div class="col mt-0">
          {% capture study_type %}
            {% if entry.studyType %}{{ entry.studyType }}{% elsif entry.degree %}{{ entry.degree }}{% endif %}
          {% endcapture %}

          {% if entry.url %}
            <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">
              <a href="{{ entry.url }}">{{ study_type }}{% if entry.area %} in {{ entry.area }}{% endif %}</a>
            </h6>
          {% elsif study_type != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4" style="margin-bottom: 0.15rem;">{{ study_type }}{% if entry.area %} in {{ entry.area }}{% endif %}</h6>
          {% endif %}

          {% if entry.institution %}
            <div class="ml-1 ml-md-4" style="font-size: 0.9rem;">
              {{ entry.institution }}{% if entry.highlights.size > 0 %}{% assign first_hl = entry.highlights | first %}{% if first_hl contains 'Advisor' %} ({{ first_hl }}){% endif %}{% endif %}
            </div>
          {% endif %}

          {% if entry.highlights %}
            <ul class="items" style="margin-top: 0.1rem;">
              {% for item in entry.highlights %}
                {% unless item contains 'Advisor' %}
                  <li>
                    <span class="item" style="font-size: 0.9rem;">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                  </li>
                {% endunless %}
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
